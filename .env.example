# ── Provider switch ───────────────────────────────────────
LLM_PROVIDER=aws

# ── Environment ───────────────────────────────────────────
APP_ENV=dev

# ── AWS Bedrock ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=us-east-1
BEDROCK_MODEL_DEV=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_PROD=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Azure OpenAI ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_DEPLOYMENT_DEV=gpt-4o-mini
AZURE_DEPLOYMENT_PROD=gpt-4o

# ── Shared LLM settings ───────────────────────────────────
LLM_TEMPERATURE=0.8
LLM_max_completion_tokens=1024

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=dnd
POSTGRES_PASSWORD=dndpass
POSTGRES_DB=dnd_state
DATABASE_URL=postgresql://dnd:dndpass@localhost:5433/dnd_state

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/dnd_lore
MONGO_DB=dnd_lore

# ── App ───────────────────────────────────────────────────
SESSION_ID=player_one
CORS_ORIGIN=http://localhost:5173